# Showrunner reads provider keys server-side via SvelteKit's $env/static/private.
# Copy this file to `.env.local` and paste your keys.

# Storyboard agent — Vercel AI Gateway (preferred) routes claude-opus-4-7
AI_GATEWAY_API_KEY=

# Image generation — Replicate (openai/gpt-image-2 quality=high)
REPLICATE_API_TOKEN=

# Voiceover — ElevenLabs v3
ELEVEN_LABS_API_KEY=

# Lipsync — fal.ai (used for Veed Fabric 1.0 and Creatify Aurora)
FAL_API_KEY=
